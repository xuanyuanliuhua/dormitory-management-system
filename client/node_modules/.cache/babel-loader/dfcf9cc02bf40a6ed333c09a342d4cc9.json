  <el-button icon=\"plus\" style=\"width: 50px\" type=\"primary\" @click=\"add\"></el-button>\n              </el-tooltip>\n            </div>\n          </div>\n        </div>\n        <!--    表格-->\n        <el-table v-loading=\"loading\" :data=\"tableData\" border max-height=\"705\" style=\"width: 100%\">\n          <el-table-column label=\"#\" type=\"index\"/>\n          <el-table-column label=\"姓名\" prop=\"visitorName\" width=\"150px\"/>\n          <el-table-column\n              :filter-method=\"filterTag\"\n              :filters=\"[\n              { text: '男', value: '男' },\n              { text: '女', value: '女' },\n            ]\"\n              filter-placement=\"bottom-end\"\n              label=\"性别\"\n              prop=\"gender\"\n              width=\"130px\"\n          />\n          <el-table-column label=\"手机号\" prop=\"phoneNum\" width=\"200px\"/>\n          <el-table-column label=\"来源地\" prop=\"originCity\" sortable width=\"140px\"/>\n          <el-table-column label=\"来访时间\" prop=\"visitTime\" sortable width=\"220px\"/>\n          <el-table-column label=\"备注\" prop=\"content\" sortable/>\n          <!--      操作栏-->\n          <el-table-column label=\"操作\" width=\"130px\">\n            <template #default=\"scope\">\n              <el-button icon=\"Edit\" type=\"primary\" @click=\"handleEdit(scope.row)\"></el-button>\n              <el-popconfirm title=\"确认删除？\" @confirm=\"handleDelete(scope.row.id)\">\n                <template #reference>\n                  <el-button icon=\"Delete\" type=\"danger\"></el-button>\n                </template>\n              </el-popconfirm>\n            </template>\n          </el-table-column>\n        </el-table>\n        <!--分页-->\n        <div style=\"margin: 10px 0\">\n          <el-pagination\n              v-model:currentPage=\"currentPage\"\n              :page-size=\"pageSize\"\n              :page-sizes=\"[10, 20]\"\n              :total=\"total\"\n              layout=\"total, sizes, prev, pager, next, jumper\"\n              @size-change=\"handleSizeChange\"\n              @current-change=\"handleCurrentChange\"\n          >\n          </el-pagination>\n        </div>\n        <!--      弹窗-->\n        <div>\n          <el-dialog v-model=\"dialogVisible\" title=\"操作\" width=\"30%\" @close=\"cancel\">\n            <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"120px\">\n              <el-form-item label=\"姓名\" prop=\"visitorName\">\n                <el-input v-model=\"form.visitorName\" clearable style=\"width: 50%\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"性别\" prop=\"gender\">\n                <el-radio v-model=\"form.gender\" label=\"男\">男</el-radio>\n                <el-radio v-model=\"form.gender\" label=\"女\">女</el-radio>\n              </el-form-item>\n              <el-form-item label=\"手机号\" prop=\"phoneNum\">\n                <el-input v-model=\"form.phoneNum\" clearable style=\"width: 50%\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"来源地\" prop=\"originCity\">\n                <el-input v-model=\"form.originCity\" clearable style=\"width: 50%\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"来访时间\" prop=\"visitTime\">\n                <el-date-picker\n                    v-model=\"form.visitTime\"\n                    clearable\n                    placeholder=\"选择时间\"\n                    style=\"width: 48%\"\n                    type=\"datetime\"\n                    value-format=\"YYYY-MM-DD HH:mm:ss\"\n                ></el-date-picker>\n              </el-form-item>\n              <el-form-item label=\"来访信息\" prop=\"content\">\n                <el-input\n                    v-model=\"form.content\"\n                    :autosize=\"{ minRows: 3, maxRows: 10 }\"\n                    clearable\n                    style=\"width: 80%\"\n                    type=\"textarea\"\n                ></el-input>\n              </el-form-item>\n            </el-form>\n            <template #footer>\n              <span class=\"dialog-footer\">\n                <el-button @click=\"cancel\">取 消</el-button>\n                <el-button type=\"primary\" @click=\"save\">确 定</el-button>\n              </span>\n            </template>\n          </el-dialog>\n        </div>\n      </div>\n    </el-card>\n  </div>\n</template>\n<script src=\"@/assets/js/VisitorInfo.js\"></script>"],"mappings":";;EASaA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;;EAEpBA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;;EAIpBA,KAAoB,EAApB;IAAA;EAAA;AAAoB;;EAuCxBA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;;EAkDfC,KAAK,EAAC;AAAe;;;;;;;;;;;;;;;;;;uBAvGvCC,mBAAA,CAgHM,cA/GJC,YAAA,CAGgBC,wBAAA;IAHD,gBAAc,EAAC,YAAY;IAACJ,KAAoB,EAApB;MAAA;IAAA;;sBACzC,MAAmE,CAAnEG,YAAA,CAAmEE,6BAAA;MAA9CC,EAAE,EAAE;QAAAC,IAAA;MAAA;IAAiB;wBAAE,MAAE,C,iBAAF,IAAE,E;;QAC9CJ,YAAA,CAA6CE,6BAAA;wBAAzB,MAAI,C,iBAAJ,MAAI,E;;;;;MAE1BF,YAAA,CA0GUK,kBAAA;IA1GDR,KAAqD,EAArD;MAAA;MAAA;IAAA;EAAqD;sBAC5D,MAwGM,CAxGNS,mBAAA,CAwGM,cAvGJC,mBAAA,WAAc,EACdD,mBAAA,CAYM,OAZNE,UAYM,GAXJD,mBAAA,WAAc,EACdD,mBAAA,CASM,OATNG,UASM,GARJT,YAAA,CAAkGU,mBAAA;kBAA/EC,IAAA,CAAAC,MAAM;iEAAND,IAAA,CAAAC,MAAM,GAAAC,MAAA;MAAEC,SAAS,EAAT,EAAS;MAACC,WAAW,EAAC,OAAO;MAAC,aAAW,EAAC,QAAQ;MAAClB,KAAkB,EAAlB;QAAA;MAAA;6CAC9EG,YAAA,CAA2FgB,oBAAA;MAAhFC,IAAI,EAAC,QAAQ;MAACpB,KAAwB,EAAxB;QAAA;MAAA,CAAwB;MAACqB,IAAI,EAAC,SAAS;MAAEC,OAAK,EAAER,IAAA,CAAAS;0CACzEpB,YAAA,CAAmGgB,oBAAA;MAAxFC,IAAI,EAAC,cAAc;MAACpB,KAAyB,EAAzB;QAAA;MAAA,CAAyB;MAACqB,IAAI,EAAC,SAAS;MAAEC,OAAK,EAAER,IAAA,CAAAU;0CAChFf,mBAAA,CAIM,OAJNgB,UAIM,GAHJtB,YAAA,CAEauB,qBAAA;MAFDC,OAAO,EAAC,IAAI;MAACC,SAAS,EAAC;;wBACjC,MAAmF,CAAnFzB,YAAA,CAAmFgB,oBAAA;QAAxEC,IAAI,EAAC,MAAM;QAACpB,KAAmB,EAAnB;UAAA;QAAA,CAAmB;QAACqB,IAAI,EAAC,SAAS;QAAEC,OAAK,EAAER,IAAA,CAAAe;;;cAK1EnB,mBAAA,UAAa,E,+BACboB,YAAA,CA6BWC,mBAAA;MA7BoBC,IAAI,EAAElB,IAAA,CAAAmB,SAAS;MAAEC,MAAM,EAAN,EAAM;MAAC,YAAU,EAAC,KAAK;MAAClC,KAAmB,EAAnB;QAAA;MAAA;;wBACtE,MAAyC,CAAzCG,YAAA,CAAyCgC,0BAAA;QAAxBC,KAAK,EAAC,GAAG;QAACf,IAAI,EAA