con=\"Search\"\n              style=\"margin-left: 5px\"\n              type=\"primary\"\n              @click=\"load\"\n            ></el-button>\n            <el-button\n              icon=\"refresh-left\"\n              style=\"margin-left: 10px\"\n              type=\"default\"\n              @click=\"reset\"\n            ></el-button>\n            <div style=\"float: right\">\n              <el-tooltip content=\"添加\" placement=\"top\">\n                <el-button\n                  icon=\"plus\"\n                  v-if=\"role != 'stu'\"\n                  style=\"width: 50px\"\n                  type=\"primary\"\n                  @click=\"add\"\n                ></el-button>\n              </el-tooltip>\n            </div>\n          </div>\n          \n        </div>\n        <!--    表格-->\n        <el-table\n          v-loading=\"loading\"\n          :data=\"tableData\"\n          border\n          max-height=\"705\"\n          style=\"width: 100%\"\n        >\n          <el-table-column label=\"#\" type=\"index\" />\n          <el-table-column label=\"宿舍号\" prop=\"roomid\" sortable />\n          <el-table-column label=\"检查结果\" prop=\"grade\" />\n          <el-table-column label=\"说明原因\" prop=\"reason\" />\n          <el-table-column label=\"时间\" prop=\"date\" />\n          <el-table-column label=\"操作人\" prop=\"operatorName\" />\n          <!--      操作栏-->\n          <el-table-column v-if=\"role != 'stu'\" label=\"操作\" width=\"130px\">\n            <template #default=\"scope\">\n              <el-button\n                icon=\"Edit\"\n                type=\"primary\"\n                @click=\"handleEdit(scope.row)\"\n              ></el-button>\n              <el-popconfirm\n                title=\"确认删除？\"\n                @confirm=\"handleDelete(scope.row.id)\"\n              >\n                <template #reference>\n                  <el-button icon=\"Delete\" type=\"danger\"></el-button>\n                </template>\n              </el-popconfirm>\n            </template>\n          </el-table-column>\n        </el-table>\n        <!--分页-->\n        <div style=\"margin: 10px 0\">\n          <el-pagination\n            v-model:currentPage=\"currentPage\"\n            :page-size=\"pageSize\"\n            :page-sizes=\"[10, 20]\"\n            :total=\"total\"\n            layout=\"total, sizes, prev, pager, next, jumper\"\n            @size-change=\"handleSizeChange\"\n            @current-change=\"handleCurrentChange\"\n          >\n          </el-pagination>\n        </div>\n        <!--      弹窗-->\n        <div>\n          <el-dialog\n            v-model=\"dialogVisible\"\n            title=\"操作\"\n            width=\"30%\"\n            @close=\"cancel\"\n          >\n            <el-form\n              ref=\"form\"\n              :model=\"form\"\n              :rules=\"rules\"\n              label-width=\"120px\"\n            >\n              <el-form-item label=\"宿舍号\" prop=\"roomid\">\n                <el-input\n                  v-model=\"form.roomid\"\n                  placeholder=\"输入宿舍号\"\n                  clearable\n                  style=\"width: 80%\"\n                ></el-input>\n              </el-form-item>\n              <el-form-item label=\"检查结果\" prop=\"grade\">\n                <el-select\n                  v-model=\"form.grade\"\n                  style=\"width: 80%\"\n                  placeholder=\"请选择检查结果\"\n                >\n                  <el-option label=\"及格\" value=\"及格\"></el-option>\n                  <el-option label=\"不及格\" value=\"不及格\"></el-option>\n                </el-select>\n              </el-form-item>\n              <el-form-item label=\"说明原因\" prop=\"reason\">\n                <el-input\n                  v-model=\"form.reason\"\n                  placeholder=\"输入原因\"\n                  type=\"textarea\"\n                  :rows=\"4\"\n                  clearable\n                  style=\"width: 80%\"\n                ></el-input>\n              </el-form-item>\n            </el-form>\n            <template #footer>\n              <span class=\"dialog-footer\">\n                <el-button @click=\"cancel\">取 消</el-button>\n                <el-button type=\"primary\" @click=\"save\">确 定</el-button>\n              </span>\n            </template>\n          </el-dialog>\n        </div>\n      </div>\n    </el-card>\n  </div>\n</template>\n<script src=\"@/assets/js/CheckInfo.js\"></script>"],"mappings":";;EASaA,KAAuB,EAAvB;IAAA;EAAA;AAAuB;;EAErBA,KAAuB,EAAvB;IAAA;EAAA;AAAuB;;EA6BrBA,KAAoB,EAApB;IAAA;EAAA;AAAoB;;EAgDxBA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;;EAwDfC,KAAK,EAAC;AAAe;;;;;;;;;;;;;;;;;;;uBA/IvCC,mBAAA,CAwJM,cAvJJC,YAAA,CAGgBC,wBAAA;IAHD,gBAAc,EAAC,YAAY;IAACJ,KAAoB,EAApB;MAAA;IAAA;;sBACzC,MAAmE,CAAnEG,YAAA,CAAmEE,6BAAA;MAA9CC,EAAE,EAAE;QAAAC,IAAA;MAAA;IAAiB;wBAAE,MAAE,C,iBAAF,IAAE,E;;QAC9CJ,YAAA,CAA6CE,6BAAA;wBAAzB,MAAI,C,iBAAJ,MAAI,E;;;;;MAE1BF,YAAA,CAkJUK,kBAAA;IAlJDR,KAAqD,EAArD;MAAA;MAAA;IAAA;EAAqD;sBAC5D,MAgJM,CAhJNS,mBAAA,CAgJM,cA/IJC,mBAAA,WAAc,EACdD,mBAAA,CA4CM,OA5CNE,UA4CM,GA3CJD,mBAAA,WAAc,EACdD,mBAAA,CAwCM,OAxCNG,UAwCM,GAvCJT,YAAA,CAMEU,mBAAA;kBALSC,IAAA,CAAAC,MAAM;iEAAND,IAAA,CAAAC,MAAM,GAAAC,MAAA;MACfC,SAAS,EAAT,EAAS;MACTC,WAAW,EAAC,QAAQ;MACpB,aAAW,EAAC,QAAQ;MACpBlB,KAAwB,EAAxB;QAAA;MAAA;6CAEFG,YAAA,CAQiBgB,yBAAA;MAPjBnB,KAAyB,EAAzB;QAAA;MAAA,CAAyB;kBACdc,IAAA,CAAAM,IAAI;iEAAJN,IAAA,CAAAM,IAAI,GAAAJ,MAAA;MACbK,IAAI,EAAC,eAAe;MACpB,iBAAe,EAAC,GAAG;MACnB,mBAAiB,EAAC,MAAM;MACxB,iBAAe,EAAC;6CAGlBlB,YAAA,CAKamB,oBAAA;MAJXC,IAAI,EAAC,QAAQ;MACbvB,KAAwB,EAAxB;QAAA;MAAA,CAAwB;MACxBqB,IAAI,EAAC,SAAS;MACbG,OAAK,EAAEV,IAAA,CAAAW;0CAEVtB,YAAA,CAKamB,oBAAA;MAJXC,IAAI,EAAC,cAAc;MACnBvB,KAAyB,EAAzB;QAAA;MAAA,CAAyB;MACzBqB,IAAI,EAAC,SAAS;MACbG,OAAK,EAAEV,IAAA,CAAAY;0CAEVjB,mBAAA,CAUM,OAVNkB,UAUM,GATJxB,YAAA,CAQayB,qBAAA;MARDC,OAAO,EAAC,IAAI;MAACC,SAAS,EAAC;;wBACjC,MAMa,CAJLhB,IAAA,CAAAiB,IAAI,a,cAFZC,YAAA,CAMaV,oBAAA;;QALXC,IAAI,EAAC,MAAM;QAEXvB,KAAmB,EAAnB;UAAA;QAAA,CAAmB;QACnBqB,IAAI,EAAC,SAAS;QACbG,OAAK,EAAEV,IAAA,CAAAmB;;;cAOlBvB,m