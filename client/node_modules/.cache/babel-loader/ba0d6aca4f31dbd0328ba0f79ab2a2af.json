-descriptions-item>\n                <template #label>\n                  <div>\n                    <el-icon>\n                      <location/>\n                    </el-icon>\n                    房间号\n                  </div>\n                </template>\n                <span class=\"rightSpan\">{{ this.room.dormRoomId }}</span>\n              </el-descriptions-item>\n              <el-descriptions-item>\n                <template #label>\n                  <div>\n                    <el-icon>\n                      <tickets/>\n                    </el-icon>\n                    楼层\n                  </div>\n                </template>\n                <span class=\"rightSpan\">{{ this.room.floorNum }}</span>\n              </el-descriptions-item>\n              <el-descriptions-item>\n                <template #label>\n                  <div>\n                    <el-icon>\n                      <office-building/>\n                    </el-icon>\n                    可住人数\n                  </div>\n                </template>\n                <span class=\"rightSpan\">{{ this.room.maxCapacity }}</span>\n              </el-descriptions-item>\n              <el-descriptions-item>\n                <template #label>\n                  <div>\n                    <el-icon>\n                      <iphone/>\n                    </el-icon>\n                    已住人数\n                  </div>\n                </template>\n                <span class=\"rightSpan\">{{ this.room.currentCapacity }}</span>\n              </el-descriptions-item>\n            </el-descriptions>\n          </div>\n          <!--      床位信息-->\n          <div style=\"margin-left: 50px;margin-top: 40px\">\n            <el-descriptions :column=\"1\" border style=\"width: 500px\" title=\"床位信息\">\n              <el-descriptions-item>\n                <template #label>\n                  <div>\n                    <el-icon>\n                      <user/>\n                    </el-icon>\n                    一号床位\n                  </div>\n                </template>\n                <el-tag\n                    v-if=\"this.room.firstBed != null\"\n                    :type=\"this.name === this.room.firstBed ? 'primary':'info'\"\n                    disable-transitions\n                >{{ this.room.firstBed }}\n                </el-tag>\n              </el-descriptions-item>\n              <el-descriptions-item>\n                <template #label>\n                  <div>\n                    <el-icon>\n                      <location/>\n                    </el-icon>\n                    二号床位\n                  </div>\n                </template>\n                <el-tag\n                    v-if=\"this.room.secondBed != null\"\n                    :type=\"this.name === this.room.secondBed ? 'primary':'info'\"\n                    disable-transitions\n                >{{ this.room.secondBed }}\n                </el-tag>\n              </el-descriptions-item>\n              <el-descriptions-item>\n                <template #label>\n                  <div>\n                    <el-icon>\n                      <tickets/>\n                    </el-icon>\n                    三号床位\n                  </div>\n                </template>\n                <el-tag\n                    v-if=\"this.room.thirdBed != null\"\n                    :type=\"this.name === this.room.thirdBed ? 'primary':'info'\"\n                    disable-transitions\n                >{{ this.room.thirdBed }}\n                </el-tag>\n              </el-descriptions-item>\n              <el-descriptions-item>\n                <template #label>\n                  <div>\n                    <el-icon>\n                      <office-building/>\n                    </el-icon>\n                    四号床位\n                  </div>\n                </template>\n                <el-tag\n                    v-if=\"this.room.fourthBed != null\"\n                    :type=\"this.name === this.room.fourthBed ? 'primary':'info'\"\n                    disable-transitions\n                >{{ this.room.fourthBed }}\n                </el-tag>\n              </el-descriptions-item>\n            </el-descriptions>\n          </div>\n        </div>\n        <div style=\"margin-left: 100px;margin-top: 85px\">\n          <img alt=\"\" src=\"../../public/myRoom.png\" style=\"width: 600px\">\n        </div>\n      </div>\n    </el-card>\n  </div>\n</template>\n<script src=\"@/assets/js/MyRoomInfo.js\"></script>\n<style scoped>@import '../assets/css/MyRoomInfo.css';</style>"],"mappings":";OA4IsBA,UAA6B;;;EArIxCC,KAAqB,EAArB;IAAA;EAAA;AAAqB;;EACnBA,KAAwB,EAAxB;IAAA;EAAA;AAAwB;;EACtBA,KAA0C,EAA1C;IAAA;IAAA;EAAA;AAA0C;;EAYnCC,KAAK,EAAC;AAAW;;EAWjBA,KAAK,EAAC;AAAW;;EAWjBA,KAAK,EAAC;AAAW;;EAWjBA,KAAK,EAAC;AAAW;;EAWjBA,KAAK,EAAC;AAAW;;EAKxBD,KAA0C,EAA1C;IAAA;IAAA;EAAA;AAA0C;iEAqEjDE,mBAAA,CAEM;EAFDF,KAA2C,EAA3C;IAAA;IAAA;EAAA;AAA2C,I,aAC9CE,mBAAA,CAA+D;EAA1DC,GAAG,EAAC,EAAE;EAACC,GAA6B,EAA7BL,UAA6B;EAACC,KAAoB,EAApB;IAAA;EAAA;;;;;;;;;;;;;;;;uBA3IlDK,mBAAA,CA+IM,cA9IJC,YAAA,CAGgBC,wBAAA;IAHD,gBAAc,EAAC,YAAY;IAACP,KAAoB,EAApB;MAAA;IAAA;;sBACzC,MAAmE,CAAnEM,YAAA,CAAmEE,6BAAA;MAA9CC,EAAE,EAAE;QAAAC,IAAA;MAAA;IAAiB;wBAAE,MAAE,C,iBAAF,IAAE,E;;QAC9CJ,YAAA,CAA6CE,6BAAA;wBAAzB,MAAI,C,iBAAJ,MAAI,E;;;;;MAE1BF,YAAA,CAyIUK,kBAAA;IAzIDX,KAAqD,EAArD;MAAA;MAAA;IAAA;EAAqD;sBAC5D,MAuIM,CAvINE,mBAAA,CAuIM,OAvINU,UAuIM,GAtIJV,mBAAA,CAkIM,OAlINW,UAkIM,GAjIJX,mBAAA,CA2DM,OA3DNY,UA2DM,GA1DJC,mBAAA,cAAiB,EACjBT,YAAA,CAwDkBU,0BAAA;MAxDAC,MAAM,EAAE,CAAC;MAAEC,MAAM,EAAN,EAAM;MAAClB,KAAoB,EAApB;QAAA;MAAA,CAAoB;MAACmB,KAAK,EAAC;;wBAC7D,MAUuB,CAVvBb,YAAA,CAUuBc,+BAAA;QATVC,KAAK,EAAAC,QAAA,CACd,MAKM,CALNpB,mBAAA,CAKM,cAJJI,YAAA,CAEUiB,kBAAA;4BADR,MAAO,CAAPjB,YAAA,CAAOkB,eAAA,E;;6BACC,OAEZ,E;0BAEF,MAA0D,CAA1DtB,mBAAA,CAA0D,QAA1DuB,UAA0D,EAAAC,gBAAA,MAA1BC,IAAI,CAACC,WAAW,iB;;;UAElDtB,YAAA,CAUuBc,+BAAA;QATVC,KAAK,EAAAC,QAAA,CACd,MAKM,CALNpB,mBAAA,CAKM,cAJJI,YAAA,CAEUiB,kBAAA;4BADR,MAAW,CAAXjB,YAAA,CAAWuB,mBAAA,E;;6BACH,OAEZ,E