mManager') {\n        return 1\n      } else\n        return 2\n    }\n  },\n}\n</script>\n\n<style scoped>\n.icon {\n  margin-right: 6px;\n}\n\n.el-sub-menu .el-menu-item {\n  height: 50px;\n  line-height: 50px;\n  padding: 0 45px;\n  min-width: 199px;\n}\n</style>"],"mappings":";OAQkBA,UAAuB;;gEADrCC,mBAAA,CAEM;EAFDC,KAAkF,EAAlF;IAAA;IAAA;IAAA;IAAA;EAAA;AAAkF,I,aACrFD,mBAAA,CAAyD;EAApDE,GAAG,EAAC,EAAE;EAACC,GAAuB,EAAvBJ,UAAuB;EAACE,KAAoB,EAApB;IAAA;EAAA;;gEAMpCD,mBAAA,CAAe,cAAT,IAAE;gEAONA,mBAAA,CAAiB,cAAX,MAAI;gEAUVA,mBAAA,CAAiB,cAAX,MAAI;gEAUVA,mBAAA,CAAiB,cAAX,MAAI;gEAUVA,mBAAA,CAAiB,cAAX,MAAI;;EAKPI,KAAK,EAAC,MAAM;EAAC,iBAAe,EAAC,EAAE;EAACH,KAAyC,EAAzC;IAAA;IAAA;EAAA,CAAyC;EACzEI,OAAO,EAAC,eAAe;EACvBC,KAAK,EAAC;;gEACTN,mBAAA,CAE+B;EAD3BO,CAAC,EAAC,iXAAiX;EACnXC,IAAI,EAAC;;oBAFTC,UAE+B,C;iEAEjCT,mBAAA,CAAiB,cAAX,MAAI;iEAMVA,mBAAA,CAAiB,cAAX,MAAI;iEAMVA,mBAAA,CAAiB,cAAX,MAAI;iEAMVA,mBAAA,CAAiB,cAAX,MAAI;iEAORA,mBAAA,CAAkB,cAAZ,OAAK;iEASbA,mBAAA,CAAiB,cAAX,MAAI;iEAMVA,mBAAA,CAAiB,cAAX,MAAI;;;;;;;;;;;;;;;;;uBAtGdU,YAAA,CAwGUC,kBAAA;IAvGL,gBAAc,OAAOC,IAAI;IAC1BC,MAAM,EAAN,EAAM;IACNZ,KAAiE,EAAjE;MAAA;MAAA;MAAA;IAAA,CAAiE;IACjE,eAAa,EAAb;;sBAEF,MAEM,CAFNa,UAEM,EACNC,YAAA,CAKeC,uBAAA;MALDC,KAAK,EAAC;IAAO;wBACzB,MAEU,CAFVF,YAAA,CAEUG,kBAAA;0BADR,MAAQ,CAARH,YAAA,CAAQI,gBAAA,E;;UAEVC,UAAe,C;;aAEOC,aAAa,Y,cAArCX,YAAA,CAScY,sBAAA;;MAT+BL,KAAK,EAAC;;MACtCM,KAAK,EAAAC,QAAA,CACd,MAEU,CAFVT,YAAA,CAEUG,kBAAA;0BADR,MAAO,CAAPH,YAAA,CAAOU,eAAA,E;;UAETC,UAAiB,C;wBAEnB,MAAkF,C,KAAzDL,aAAa,Y,cAAtCX,YAAA,CAAkFM,uBAAA;;QAApCC,KAAK,EAAC;;0BAAW,MAAI,C,iBAAJ,MAAI,E;;oDAC1CI,aAAa,Y,cAAtCX,YAAA,CAA0FM,uBAAA;;QAA5CC,KAAK,EAAC;;0BAAmB,MAAI,C,iBAAJ,MAAI,E;;;;kDAErDI,aAAa,Y,cAArCX,YAAA,CAScY,sBAAA;;MAT+BL,KAAK,EAAC;;MACtCM,KAAK,EAAAC,QAAA,CACd,MAEU,CAFVT,YAAA,CAEUG,kBAAA;0BADR,MAAO,CAAPH,YAAA,CAAOY,eAAA,E;;UAETC,UAAiB,C;wBAEnB,MAAuF,C,KAA9DP,aAAa,Y,cAAtCX,YAAA,CAAuFM,uBAAA;;QAAzCC,KAAK,EAAC;;0BAAgB,MAAI,C,iBAAJ,MAAI,E;;oDAC/CI,aAAa,Y,cAAtCX,YAAA,CAAmFM,uBAAA;;QAArCC,KAAK,EAAC;;0BAAY,MAAI,C,iBAA