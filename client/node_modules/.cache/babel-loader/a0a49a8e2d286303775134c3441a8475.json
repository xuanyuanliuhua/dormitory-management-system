=\"top\">\n                <el-button icon=\"plus\" style=\"width: 50px\" type=\"primary\" @click=\"add\"></el-button>\n              </el-tooltip>\n            </div>\n          </div>\n        </div>\n        <!--    表格-->\n        <el-table v-loading=\"loading\" :data=\"tableData\" border max-height=\"705\" style=\"width: 100%\">\n          <el-table-column label=\"#\" type=\"index\"/>\n          <el-table-column :show-overflow-tooltip=\"true\" label=\"标题\" prop=\"title\"/>\n          <el-table-column label=\"作者\" prop=\"author\" width=\"150px\"/>\n          <el-table-column label=\"发布时间\" prop=\"releaseTime\" sortable width=\"400px\"/>\n          <!--      操作栏-->\n          <el-table-column label=\"操作\" width=\"190px\">\n            <template #default=\"scope\">\n              <el-button icon=\"more-filled\" type=\"default\" @click=\"showDetail(scope.row)\"></el-button>\n              <el-button icon=\"Edit\" type=\"primary\" @click=\"handleEdit(scope.row)\"></el-button>\n              <el-popconfirm title=\"确认删除？\" @confirm=\"handleDelete(scope.row.id)\">\n                <template #reference>\n                  <el-button icon=\"Delete\" type=\"danger\"></el-button>\n                </template>\n              </el-popconfirm>\n            </template>\n          </el-table-column>\n        </el-table>\n        <!--分页-->\n        <div style=\"margin: 10px 0\">\n          <el-pagination\n              v-model:currentPage=\"currentPage\"\n              :page-size=\"pageSize\"\n              :page-sizes=\"[10, 20]\"\n              :total=\"total\"\n              layout=\"total, sizes, prev, pager, next, jumper\"\n              @size-change=\"handleSizeChange\"\n              @current-change=\"handleCurrentChange\"\n          >\n          </el-pagination>\n        </div>\n        <!--      弹窗-->\n        <div>\n          <el-dialog v-model=\"dialogVisible\" title=\"操作\" width=\"50%\" @close=\"cancel\">\n            <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"120px\">\n              <el-form-item label=\"标题\" prop=\"title\" style=\"margin-bottom: 27px\">\n                <el-input v-model=\"form.title\" clearable style=\"width: 50%\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"内容\" prop=\"content\">\n                <div id=\"div1\" style=\"width: 74%; margin: 4px 0\"></div>\n              </el-form-item>\n              <el-form-item label=\"发布时间\" prop=\"releaseTime\" style=\"margin-top: 27px\">\n                <el-date-picker\n                    v-model=\"form.releaseTime\"\n                    clearable\n                    placeholder=\"选择时间\"\n                    type=\"datetime\"\n                    value-format=\"YYYY-MM-DD HH:mm:ss\"\n                ></el-date-picker>\n              </el-form-item>\n            </el-form>\n            <template #footer>\n              <span class=\"dialog-footer\">\n                <el-button @click=\"cancel\">取 消</el-button>\n                <el-button type=\"primary\" @click=\"save\">确 定</el-button>\n              </span>\n            </template>\n          </el-dialog>\n          <!--    公告详情-->\n          <el-dialog v-model=\"detailDialog\" title=\"详情\" width=\"50%\">\n            <el-card>\n              <div v-html=\"detail.content\"></div>\n            </el-card>\n            <template #footer>\n              <span class=\"dialog-footer\">\n                <el-button type=\"primary\" @click=\"closeDetailDialog\">确 定</el-button>\n              </span>\n            </template>\n          </el-dialog>\n        </div>\n      </div>\n    </el-card>\n  </div>\n</template>\n<script src=\"@/assets/js/NoticeInfo.js\"></script>"],"mappings":";;EAUaA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;;EAEpBA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;;EAIpBA,KAAoB,EAApB;IAAA;EAAA;AAAoB;;EA2BxBA,KAAsB,EAAtB;IAAA;EAAA;AAAsB;gCAoBnBC,mBAAA,CAAuD;EAAlDC,EAAE,EAAC,MAAM;EAACF,KAAiC,EAAjC;IAAA;IAAA;EAAA;;;EAaXG,KAAK,EAAC;AAAe;;;EAYrBA,KAAK,EAAC;AAAe;;;;;;;;;;;;;;;;;uBAvF