table-column label=\"操作\">\n            <template #default=\"scope\">\n              <el-button\n                icon=\"more-filled\"\n                type=\"default\"\n                @click=\"handleEdit(scope.row)\"\n              ></el-button>\n            </template>\n          </el-table-column>\n        </el-table>\n        <!--分页-->\n        <div style=\"margin: 10px 0\">\n          <el-pagination\n            v-model:currentPage=\"currentPage\"\n            :page-size=\"pageSize\"\n            :page-sizes=\"[10, 20]\"\n            :total=\"total\"\n            layout=\"total, sizes, prev, pager, next, jumper\"\n            @size-change=\"handleSizeChange\"\n            @current-change=\"handleCurrentChange\"\n          >\n          </el-pagination>\n        </div>\n        <!--      弹窗-->\n        <div>\n          <el-dialog\n            v-model=\"dialogVisible\"\n            :title=\"title\"\n            width=\"30%\"\n            @close=\"cancel\"\n          >\n            <el-form\n              ref=\"form\"\n              :model=\"form\"\n              label-width=\"120px\"\n            >\n               <el-form-item label=\"类型\" prop=\"type\">\n                <el-input\n                  v-model=\"form.type\"\n                  disabled\n                  clearable\n                  style=\"width: 80%\"\n                ></el-input>\n              </el-form-item>\n\n              <el-form-item label=\"宿舍号\" v-if=\"role != 'stu' || disabled\" prop=\"roomid\">\n                <el-input\n                  v-model=\"form.roomid\"\n                  :disabled=\"disabled\"\n                  clearable\n                  style=\"width: 80%\"\n                ></el-input>\n              </el-form-item>\n              <el-form-item label=\"金额\" prop=\"money\">\n                <el-input-number\n                  :disabled=\"disabled\"\n                  v-model=\"form.money\"\n                  style=\"width: 80%\"\n                  :precision=\"2\"\n      